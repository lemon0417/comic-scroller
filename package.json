{
  "name": "comicsscroller",
  "version": "4.0.51",
  "private": true,
  "scripts": {
    "clean": "shx rm -rf ./ComicsScroller",
    "mkdir": "shx mkdir -p ./ComicsScroller/{js,css}",
    "copy:dev": "shx cp -r ./src/extensions/* ./ComicsScroller/ && shx rm -rf ./ComicsScroller/{app,popup}.html && shx mv ./ComicsScroller/app_dev.html ./ComicsScroller/app.html && shx mv ./ComicsScroller/popup_dev.html ./ComicsScroller/popup.html",
    "set:dev": "npm run clean && npm run mkdir && npm run copy:dev ",
    "compile:background": "webpack --config webpack.config.bg.js",
    "start": "npm run set:dev && npm run compile:background && node server.js",
    "set:prod": "npm run clean && npm run mkdir && npm run copy:prod",
    "copy:prod": "shx cp -r ./src/extensions/* ./ComicsScroller/ && shx rm -rf ./ComicsScroller/{app,popup}_dev.html",
    "build": "tsc && npm run set:prod && npm run compile:background && webpack --config webpack.config.prod.js",
    "zip": "shx rm -rf *.zip && bestzip ComicsScroller.zip ./ComicsScroller",
    "format": "prettier --trailing-comma=all --write 'src/js/**/*.{js,jsx}'",
    "test": "jest"
  },
  "jest": {
    "moduleNameMapper": {
      "^node:stream$": "<rootDir>/node_modules/stream-browserify/index.js",
      "^stream$": "<rootDir>/node_modules/stream-browserify/index.js",
      "^node:http$": "<rootDir>/node_modules/empty/index.js",
      "^http$": "<rootDir>/node_modules/empty/index.js",
      "^node:https$": "<rootDir>/node_modules/empty/index.js",
      "^https$": "<rootDir>/node_modules/empty/index.js",
      "^node:net$": "<rootDir>/node_modules/empty/index.js",
      "^net$": "<rootDir>/node_modules/empty/index.js",
      "^node:tls$": "<rootDir>/node_modules/empty/index.js",
      "^tls$": "<rootDir>/node_modules/empty/index.js",
      "^node:zlib$": "<rootDir>/node_modules/empty/index.js",
      "^zlib$": "<rootDir>/node_modules/empty/index.js",
      "^undici$": "<rootDir>/node_modules/empty/index.js",
      "^parse5-parser-stream$": "<rootDir>/node_modules/empty/index.js",
      "^node:(.*)$": "$1",
      "\\.(svg)$": "<rootDir>/src/js/__mocks__/svgMock.jsx",
      "\\.(css)$": "identity-obj-proxy",
      "^css/(.*)$": "<rootDir>/src/css/$1",
      "^imgs/(.*)$": "<rootDir>/src/imgs/$1",
      "^cmp/(.*)$": "<rootDir>/src/js/component/$1"
    },
    "transform": {
      "^.+\\.jsx?$": "babel-jest",
      "^.+\\.tsx?$": "ts-jest"
    },
    "moduleFileExtensions": [
      "js",
      "jsx",
      "ts",
      "tsx",
      "json",
      "node"
    ],
    "setupFiles": [
      "<rootDir>/src/js/setupTests.js"
    ],
    "verbose": true
  },
  "dependencies": {
    "babel-core": "^6.21.0",
    "babel-eslint": "^8.2.2",
    "babel-jest": "^22.4.1",
    "babel-loader": "^7.1.3",
    "babel-plugin-lodash": "^3.2.11",
    "babel-plugin-transform-runtime": "^6.22.0",
    "babel-preset-env": "^1.1.8",
    "babel-preset-react": "^6.16.0",
    "babel-preset-react-optimize": "^1.0.1",
    "babel-preset-stage-2": "^6.24.1",
    "babel-runtime": "^6.20.0",
    "bestzip": "^1.1.4",
    "body-parser": "^1.15.2",
    "cookie-parser": "^1.4.3",
    "css-loader": "^0.28.10",
    "empty": "^0.10.1",
    "eslint": "^4.18.1",
    "eslint-config-airbnb": "^16.0.0",
    "eslint-config-prettier": "^2.0.0",
    "eslint-import-resolver-webpack": "^0.8.0",
    "eslint-plugin-import": "^2.9.0",
    "eslint-plugin-jsx-a11y": "^6.0.2",
    "eslint-plugin-react": "^7.7.0",
    "express": "^4.14.0",
    "extract-text-webpack-plugin": "^3.0.0",
    "html-webpack-plugin": "^2.28.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^22.4.2",
    "jsdom": "^11.6.2",
    "lodash": "^4.17.5",
    "lodash-webpack-plugin": "^0.11.0",
    "normalize.css": "^8.0.0",
    "postcss-loader": "^2.1.1",
    "postcss-nested": "^3.0.0",
    "prettier": "^1.11.0",
    "react": "^16.2.0",
    "react-dom": "^16.2.0",
    "react-redux": "^5.0.7",
    "react-svg-loader": "^2.1.0",
    "redux": "^3.6.0",
    "redux-observable": "^0.18.0",
    "reselect": "^3.0.0",
    "rxjs": "^5.3.1",
    "shx": "^0.2.2",
    "style-loader": "^0.20.2",
    "typescript": "^4.5.4",
    "webpack": "^3.11.0",
    "webpack-dev-server": "^2.11.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/enzyme": "^3.1.0",
    "@types/lodash": "^4.17.5",
    "@types/react-redux": "^5.0.7",
    "@types/react-test-renderer": "^18.3.0",
    "@types/redux-logger": "^3.0.0",
    "cheerio": "0.22.0",
    "enzyme": "^3.1.0",
    "enzyme-adapter-react-16": "^1.15.7",
    "react-test-renderer": "^16.0.0",
    "react-hot-loader": "^4.0.0",
    "redux-logger": "^3.0.0",
    "stream-browserify": "^3.0.0",
    "ts-jest": "^22.4.6"
  }
}
