{
  "name": "comicsscroller",
  "version": "4.0.51",
  "private": true,
  "scripts": {
    "clean": "node scripts/prepare-extension.mjs clean",
    "mkdir": "node scripts/prepare-extension.mjs mkdir",
    "copy:dev": "node scripts/prepare-extension.mjs copy dev",
    "set:dev": "yarn clean && yarn copy:dev",
    "compile:background": "NODE_OPTIONS=--openssl-legacy-provider webpack --config webpack.config.bg.js",
    "start": "yarn set:dev && vite build --watch --mode development",
    "set:prod": "yarn clean && yarn copy:prod",
    "copy:prod": "node scripts/prepare-extension.mjs copy prod",
    "build": "yarn set:prod && vite build",
    "build:assets": "node scripts/copy-css-to-build.js",
    "build:webpack": "tsc -p tsconfig.build.json && yarn build:assets && yarn set:prod && yarn compile:background && NODE_OPTIONS=--openssl-legacy-provider webpack --config webpack.config.prod.js",
    "zip": "node scripts/prepare-extension.mjs clean-zip && bestzip ComicsScroller.zip ./ComicsScroller",
    "format": "prettier --trailing-comma=all --write 'src/js/**/*.{js,jsx,ts,tsx}'",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix",
    "test": "jest"
  },
  "jest": {
    "moduleNameMapper": {
      "^node:stream$": "<rootDir>/node_modules/stream-browserify/index.js",
      "^stream$": "<rootDir>/node_modules/stream-browserify/index.js",
      "^node:http$": "<rootDir>/node_modules/empty/index.js",
      "^http$": "<rootDir>/node_modules/empty/index.js",
      "^node:https$": "<rootDir>/node_modules/empty/index.js",
      "^https$": "<rootDir>/node_modules/empty/index.js",
      "^node:net$": "<rootDir>/node_modules/empty/index.js",
      "^net$": "<rootDir>/node_modules/empty/index.js",
      "^node:tls$": "<rootDir>/node_modules/empty/index.js",
      "^tls$": "<rootDir>/node_modules/empty/index.js",
      "^node:zlib$": "<rootDir>/node_modules/empty/index.js",
      "^zlib$": "<rootDir>/node_modules/empty/index.js",
      "^undici$": "<rootDir>/node_modules/empty/index.js",
      "^parse5-parser-stream$": "<rootDir>/node_modules/empty/index.js",
      "^node:(.*)$": "$1",
      "\\.(svg)$": "<rootDir>/src/js/__mocks__/svgMock.tsx",
      "\\.(css)$": "identity-obj-proxy",
      "^css/(.*)$": "<rootDir>/src/css/$1",
      "^imgs/(.*)$": "<rootDir>/src/imgs/$1",
      "^cmp/(.*)$": "<rootDir>/src/js/component/$1"
    },
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": {
            "jsx": "react-jsx"
          },
          "diagnostics": false
        }
      ]
    },
    "moduleFileExtensions": [
      "js",
      "jsx",
      "ts",
      "tsx",
      "json",
      "node"
    ],
    "testMatch": [
      "**/__tests__/**/*.(js|jsx|ts|tsx)",
      "**/?(*.)+(spec|test).(js|jsx|ts|tsx)"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/js/setupTests.ts"
    ],
    "verbose": true
  },
  "dependencies": {
    "@reduxjs/toolkit": "2.11.0",
    "babel-core": "^6.21.0",
    "babel-jest": "^22.4.1",
    "babel-loader": "^7.1.3",
    "babel-plugin-lodash": "^3.2.11",
    "babel-plugin-transform-runtime": "^6.22.0",
    "babel-preset-env": "^1.1.8",
    "babel-preset-react": "^6.16.0",
    "babel-preset-react-optimize": "^1.0.1",
    "babel-preset-stage-2": "^6.24.1",
    "babel-runtime": "^6.20.0",
    "bestzip": "^1.1.4",
    "body-parser": "^1.15.2",
    "cookie-parser": "^1.4.3",
    "css-loader": "^0.28.10",
    "empty": "^0.10.1",
    "express": "^4.14.0",
    "extract-text-webpack-plugin": "^3.0.0",
    "html-webpack-plugin": "^2.28.0",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^11.6.2",
    "lodash": "^4.17.5",
    "lodash-webpack-plugin": "^0.11.0",
    "normalize.css": "^8.0.0",
    "postcss-loader": "^2.1.1",
    "postcss-nested": "^3.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-redux": "9.2.0",
    "react-svg-loader": "^2.1.0",
    "redux": "5.0.1",
    "redux-observable": "2.0.0-rc.2",
    "reselect": "^3.0.0",
    "rxjs": "7.8.2",
    "style-loader": "^0.20.2",
    "typescript": "5.9.2",
    "webpack": "^3.11.0",
    "webpack-dev-server": "^2.11.2"
  },
  "devDependencies": {
    "@eslint/js": "9.18.0",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.2.0",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.5",
    "@types/node": "24.10.9",
    "@types/react": "18.3.26",
    "@types/react-dom": "18.3.7",
    "@types/react-test-renderer": "18.3.1",
    "@types/redux-logger": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "8.42.0",
    "@typescript-eslint/parser": "8.42.0",
    "@vitejs/plugin-react": "5.1.3",
    "cheerio": "0.22.0",
    "eslint": "9.18.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-webpack": "0.8.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "globals": "17.3.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "prettier": "3.6.2",
    "react-test-renderer": "18.2.0",
    "redux-logger": "^3.0.0",
    "stream-browserify": "^3.0.0",
    "ts-jest": "29.4.0",
    "vite": "7.3.1",
    "vite-plugin-svgr": "^4.2.0"
  },
  "resolutions": {
    "@types/react": "18.3.26",
    "@types/react-dom": "18.3.7"
  }
}
