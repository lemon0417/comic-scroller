{
  "name": "comic-scroller",
  "version": "4.0.52",
  "private": true,
  "packageManager": "yarn@4.0.2",
  "engines": {
    "node": ">=22.22.0",
    "yarn": ">=4.0.0"
  },
  "scripts": {
    "start": "vite build --watch --mode development",
    "build": "vite build",
    "prepare": "husky install",
    "version:bump": "node scripts/bump-version.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "typecheck": "tsc --noEmit",
    "typecheck:emit": "tsc -p tsconfig.build.json",
    "zip": "node scripts/zip-release.mjs",
    "release": "yarn verify:release && yarn lint && yarn test && yarn build && yarn zip",
    "format": "prettier --trailing-comma=all --write 'src/js/**/*.{js,jsx,ts,tsx}'",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix",
    "test": "jest"
  },
  "jest": {
    "moduleNameMapper": {
      "^node:stream$": "<rootDir>/node_modules/stream-browserify/index.js",
      "^stream$": "<rootDir>/node_modules/stream-browserify/index.js",
      "^node:http$": "<rootDir>/node_modules/empty/index.js",
      "^http$": "<rootDir>/node_modules/empty/index.js",
      "^node:https$": "<rootDir>/node_modules/empty/index.js",
      "^https$": "<rootDir>/node_modules/empty/index.js",
      "^node:net$": "<rootDir>/node_modules/empty/index.js",
      "^net$": "<rootDir>/node_modules/empty/index.js",
      "^node:tls$": "<rootDir>/node_modules/empty/index.js",
      "^tls$": "<rootDir>/node_modules/empty/index.js",
      "^node:zlib$": "<rootDir>/node_modules/empty/index.js",
      "^zlib$": "<rootDir>/node_modules/empty/index.js",
      "^undici$": "<rootDir>/node_modules/empty/index.js",
      "^parse5-parser-stream$": "<rootDir>/node_modules/empty/index.js",
      "^node:(.*)$": "$1",
      "\\.svg\\?react$": "<rootDir>/src/js/__mocks__/svgMock.tsx",
      "\\.(svg)$": "<rootDir>/src/js/__mocks__/svgMock.tsx",
      "\\.(css)$": "identity-obj-proxy",
      "^css/(.*)$": "<rootDir>/src/css/$1",
      "^imgs/(.*)$": "<rootDir>/src/imgs/$1",
      "^cmp/(.*)$": "<rootDir>/src/js/component/$1"
    },
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": {
            "jsx": "react-jsx"
          },
          "diagnostics": false
        }
      ]
    },
    "moduleFileExtensions": [
      "js",
      "jsx",
      "ts",
      "tsx",
      "json",
      "node"
    ],
    "testMatch": [
      "**/__tests__/**/*.(js|jsx|ts|tsx)",
      "**/?(*.)+(spec|test).(js|jsx|ts|tsx)"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/js/setupTests.ts"
    ],
    "verbose": true
  },
  "dependencies": {
    "@reduxjs/toolkit": "2.11.0",
    "lodash": "^4.17.5",
    "normalize.css": "^8.0.0",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-redux": "9.2.0",
    "redux": "5.0.1",
    "redux-observable": "3.0.0-rc.3",
    "reselect": "^3.0.0",
    "rxjs": "7.8.2",
    "typescript": "5.9.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/js": "9.18.0",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.2.0",
    "@types/archiver": "^7",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.5",
    "@types/node": "24.10.9",
    "@types/react": "19.1.12",
    "@types/react-dom": "19.1.9",
    "@types/react-test-renderer": "19.1.0",
    "@types/redux-logger": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "8.42.0",
    "@typescript-eslint/parser": "8.42.0",
    "@vitejs/plugin-react": "5.1.3",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.4.0",
    "conventional-changelog-cli": "^5.0.0",
    "empty": "^0.10.1",
    "eslint": "9.18.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "globals": "17.3.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "postcss": "^8.4.0",
    "postcss-nested": "^3.0.0",
    "prettier": "3.6.2",
    "react-test-renderer": "19.1.1",
    "redux-logger": "^3.0.0",
    "stream-browserify": "^3.0.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "29.4.0",
    "vite": "7.3.1",
    "vite-plugin-svgr": "^4.2.0"
  },
  "resolutions": {
    "@types/react": "19.1.12",
    "@types/react-dom": "19.1.9"
  }
}
