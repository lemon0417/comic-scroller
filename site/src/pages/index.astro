---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { LinkCard } from "@astrojs/starlight/components";
import type { StarlightPageProps } from "@astrojs/starlight/props";

const heroImageHtml = `
  <div class="reader-preview" aria-hidden="true">
    <div class="reader-preview__orb reader-preview__orb--one"></div>
    <div class="reader-preview__orb reader-preview__orb--two"></div>
    <div class="reader-preview__window">
      <div class="reader-preview__appbar">
        <div class="reader-preview__menu">
          <span></span>
        </div>
        <div class="reader-preview__brandline">
          <span class="reader-preview__brand-stack">
            <span class="reader-preview__brand-block reader-preview__brand-block--wide"></span>
            <span class="reader-preview__brand-block reader-preview__brand-block--mid"></span>
          </span>
          <span class="reader-preview__brand-divider"></span>
          <span class="reader-preview__chapter-block"></span>
        </div>
        <div class="reader-preview__toolbar">
          <span class="reader-preview__tool"></span>
          <span class="reader-preview__tool"></span>
          <span class="reader-preview__tool reader-preview__tool--tag"></span>
          <span class="reader-preview__tool"></span>
        </div>
      </div>
      <div class="reader-preview__viewport">
        <div class="reader-preview__canvas">
          <div class="reader-preview__stream">
            <div class="reader-preview__image reader-preview__image--lead"></div>
            <div class="reader-preview__image reader-preview__image--mid"></div>
            <div class="reader-preview__image reader-preview__image--tail"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
`;

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${basePath}${path.replace(/^\/+/, "")}`;

const frontmatter: StarlightPageProps["frontmatter"] = {
  title: "Comic Scroller",
  description: "Reader-first browser extension for manga sites.",
  template: "splash",
  hero: {
    title: "A cleaner manga reader.",
    tagline:
      "Redirect supported chapter pages into a focused reader with local history, follows, and quick updates.",
    image: {
      html: heroImageHtml,
    },
    actions: [
      {
        text: "Install from Releases",
        link: "https://github.com/lemon0417/comic-scroller/releases",
        icon: "external",
      },
      {
        text: "Read the Install Guide",
        link: withBase("install/"),
        variant: "minimal",
        icon: "right-arrow",
      },
    ],
  },
  editUrl: false,
};

const releaseHref = "https://github.com/lemon0417/comic-scroller/releases";
const readerShotSrc = withBase("showcase/app.jpg");
const manageShotSrc = withBase("showcase/data.jpg");
const popupShotSrc = withBase("showcase/popup.jpg");
---

<StarlightPage frontmatter={frontmatter}>
  <div class="product-home">
    <section class="proof-strip" aria-label="Key product signals">
      <div>
        <span class="proof-strip__label">Supported sites</span>
        <strong>DM5, SFACG, ComicBus</strong>
      </div>
      <div>
        <span class="proof-strip__label">Reading benefit</span>
        <strong>Cleaner reader, remembered progress</strong>
      </div>
      <div>
        <span class="proof-strip__label">Install path</span>
        <strong>Install from GitHub Releases</strong>
      </div>
    </section>

    <section class="story-section story-section--split">
      <div class="story-copy">
        <p class="kicker">Why it feels different</p>
        <h2>Keep reading.</h2>
        <p>
          Open supported chapters in a cleaner reader with less clutter and quicker returns between
          chapters.
        </p>
      </div>
      <div class="highlight-stack">
        <article class="highlight-card">
          <span class="highlight-card__index">01</span>
          <h3>Cleaner reader</h3>
          <p>
            Keep chapter images front and center.
          </p>
        </article>
        <article class="highlight-card">
          <span class="highlight-card__index">02</span>
          <h3>Remember your place</h3>
          <p>
            Save local history and followed titles.
          </p>
        </article>
        <article class="highlight-card">
          <span class="highlight-card__index">03</span>
          <h3>Quick update checks</h3>
          <p>
            Check what changed from popup or manage.
          </p>
        </article>
      </div>
    </section>

    <section class="story-section story-section--showcase">
      <div class="section-heading">
        <p class="kicker">Core surfaces</p>
        <h2>Reader, popup, manage.</h2>
      </div>
      <div class="showcase-grid">
        <article class="showcase-panel showcase-panel--surface">
          <img
            class="showcase-shot"
            src={readerShotSrc}
            alt="Comic Scroller reader interface screenshot"
            loading="lazy"
          />
          <span class="showcase-panel__tag">Reader</span>
          <h3>Focused reader</h3>
          <p>
            Read chapters in a cleaner surface with navigation close by.
          </p>
        </article>
        <article class="showcase-panel showcase-panel--surface">
          <img
            class="showcase-shot"
            src={popupShotSrc}
            alt="Comic Scroller popup interface screenshot"
            loading="lazy"
          />
          <span class="showcase-panel__tag">Popup</span>
          <h3>Quick updates</h3>
          <p>
            Resume fast and scan new chapters at a glance.
          </p>
        </article>
        <article class="showcase-panel showcase-panel--surface">
          <img
            class="showcase-shot"
            src={manageShotSrc}
            alt="Comic Scroller manage page screenshot"
            loading="lazy"
          />
          <span class="showcase-panel__tag">Manage</span>
          <h3>History & follows</h3>
          <p>
            Review follows, history, and local data in one place.
          </p>
        </article>
      </div>
    </section>

    <section class="story-section story-section--install">
      <div class="section-heading">
        <p class="kicker">Install path</p>
        <h2>Install in minutes.</h2>
      </div>
      <div class="install-band">
        <ol class="install-steps">
          <li>Download the latest release asset.</li>
          <li>Extract the archive and open <code>chrome://extensions</code>.</li>
          <li>Enable developer mode and load the unpacked <code>dist/</code> folder.</li>
        </ol>
        <div class="install-band__actions">
          <a class="cta-button" href={releaseHref}>Get the latest release</a>
          <a class="text-link" href={withBase("install/")}>See the full install guide</a>
        </div>
      </div>
    </section>

    <section class="story-section story-section--sites">
      <div class="section-heading">
        <p class="kicker">Supported sites</p>
        <h2>Supported sources.</h2>
      </div>
      <ul class="site-list">
        <li>DM5 / 動漫屋</li>
        <li>SFACG</li>
        <li>ComicBus / 無限動漫</li>
      </ul>
    </section>

    <section class="story-section story-section--links">
      <div class="section-heading">
        <p class="kicker">Need more detail?</p>
        <h2>Docs & source.</h2>
      </div>
      <div class="quick-links">
        <LinkCard
          title="Install Guide"
          description="Manual install steps."
          href={withBase("install/")}
        />
        <LinkCard
          title="Development"
          description="Workspace and commands."
          href={withBase("development/")}
        />
        <LinkCard
          title="Repository"
          description="Source, releases, and issues."
          href="https://github.com/lemon0417/comic-scroller"
        />
      </div>
    </section>

    <section class="closing-banner">
      <p class="closing-banner__eyebrow">Comic Scroller</p>
      <h2>Try a cleaner reader.</h2>
      <p>
        Install the latest release and open a supported chapter page.
      </p>
      <div class="closing-banner__actions">
        <a class="cta-button" href={releaseHref}>Download the extension</a>
        <a class="text-link" href="https://github.com/lemon0417/comic-scroller">View the repository</a>
      </div>
    </section>
  </div>
</StarlightPage>
