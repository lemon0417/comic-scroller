{
  "name": "Comics Scroller",
  "version": "4.1.1",
  "manifest_version": 3,
  "description": "一個支援動漫屋、無限動漫、sfacg，給你更好的漫畫閱讀體驗的 chrome extension ",
  "icons": {
    "16": "imgs/comics-16.png",
    "48": "imgs/comics-48.png",
    "64": "imgs/comics-64.png",
    "128": "imgs/comics-128.png"
  },
  "action": {
    "default_icon": {
      "16": "imgs/comics-16.png"
    },
    "default_title": "Comics Scroller",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "js/background.js",
    "type": "module"
  },
  "permissions": [
    "alarms",
    "notifications",
    "storage",
    "tabs",
    "webNavigation",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "http://*.comicbus.com/*",
    "http://*.sfacg.com/*",
    "https://*.dm5.com/*",
    "https://*.cdndm5.com/*",
    "https://*.cdnmanhua.net/*",
    "https://github.com/*",
    "https://objects.githubusercontent.com/*",
    "https://release-assets.githubusercontent.com/*",
    "https://github-releases.githubusercontent.com/*",
    "http://localhost:5173/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "default",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' http://localhost:5173; object-src 'self';"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "js/*.js",
        "css/*.css",
        "imgs/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
