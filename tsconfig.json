{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react",
    "baseUrl": "src",
    "types": ["jest", "node"],
    "paths": {
      "@imgs": ["imgs"],
      "@imgs/*": ["imgs/*"],
      "imgs/*": ["imgs/*"],
      "@css": ["css"],
      "css/*": ["css/*"],
      "cmp": ["js/component"],
      "cmp/*": ["js/component/*"]
    },
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "build", "dist", "scripts", "webpack"]
}
